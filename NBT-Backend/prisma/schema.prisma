// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 1. Candidates (job seekers) ─────────────────────────────────
model Candidate {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  passwordHash String
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

// ── 2. Open Positions ───────────────────────────────────────────
model Job {
  id           String        @id @default(uuid())
  title        String
  team         String
  location     String
  type         String        // Full-time | Part-time | Contract | Internship
  experience   String        // e.g. "1–3 Years"
  description  String
  isActive     Boolean       @default(true)
  atsJobId     String?       @unique  // Corresponding ID in the HR/ATS tool
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

// ── 3. Applications ─────────────────────────────────────────────
model Application {
  id          String            @id @default(uuid())
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  coverLetter String?
  resumeUrl   String            // Stored on Render Disk or S3
  status      ApplicationStatus @default(APPLIED)
  atsAppId    String?           @unique  // Corresponding ID in ATS (set after sync)
  submittedAt DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  events      ApplicationEvent[]

  @@unique([candidateId, jobId])  // One application per candidate per job
}

// ── 4. Application Status Audit Trail ──────────────────────────
model ApplicationEvent {
  id            String             @id @default(uuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id])
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  changedBy     String             @default("system") // "system" | "hr" | "candidate"
  createdAt     DateTime           @default(now())
}

// ── 5. Webhook Idempotency Log ──────────────────────────────────
// Prevents duplicate processing of ATS webhook events
model WebhookEvent {
  id        String   @id @default(uuid())
  source    String   // "ats"
  eventId   String   @unique  // Idempotency key from ATS header
  payload   Json
  status    String   @default("processed") // "processed" | "failed"
  attempts  Int      @default(1)
  createdAt DateTime @default(now())
}

// ── Application Status Enum ─────────────────────────────────────
enum ApplicationStatus {
  APPLIED              // Initial state — candidate submitted
  SCREENING            // HR reviewing CV
  INTERVIEW_SCHEDULED  // Interview booked
  INTERVIEW_COMPLETED  // Interview done
  OFFER_EXTENDED       // Offer sent
  HIRED                // Candidate accepted & joined
  REJECTED             // Not selected
  WITHDRAWN            // Candidate withdrew
}
